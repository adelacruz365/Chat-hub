# ============================================================
# UNIFIED RESPONSE HUB - Variables de Entorno
# Copia este archivo a .env y rellena los valores reales
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Azure Bot Framework
MICROSOFT_APP_ID=your_azure_bot_app_id
MICROSOFT_APP_PASSWORD=your_azure_bot_app_password

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=your_whatsapp_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token

# Power Automate Webhook (salida - para notificar a PA)
POWER_AUTOMATE_WEBHOOK_URL=https://prod-xx.westeurope.logic.azure.com/workflows/...

# Secret para validar webhooks entrantes de Power Automate
WEBHOOK_SECRET=un_secreto_muy_largo_y_seguro_aqui

# (Opcional) Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key
COSMOS_DB=hub_db
COSMOS_CONTAINER=conversations

# JWT para auth de agentes (si añades login)
JWT_SECRET=otro_secreto_muy_seguro_para_jwt
